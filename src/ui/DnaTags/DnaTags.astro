---
// DnaTags — pill Geist Mono per i termini di Visual DNA (COMPONENT_RULES.md,
// componente "trasversale"). TASK_008: il click apre SearchOverlay con quel
// termine come filtro attivo — nessuno script proprio, solo l'attributo che
// il listener globale di SearchOverlay intercetta (COMPONENT_RULES.md,
// DnaTags resta "no JS"). Supersede la voce di CHANGELOG.md "DnaTags: click
// inerte" di TASK_007.
import styles from './DnaTags.module.css';

interface Props {
  terms: string[];
}

const { terms } = Astro.props;
---

{
  terms.length > 0 && (
    <ul class={styles.list} aria-label="Visual DNA">
      {terms.map((term) => (
        <li>
          <button type="button" class={`${styles.pill} text-meta`} data-search-trigger data-dna-term={term}>
            {term}
          </button>
        </li>
      ))}
    </ul>
  )
}
