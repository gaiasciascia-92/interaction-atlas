---
// PreviewLite — solo CSS, nessuna dipendenza (COMPONENT_RULES.md). Mostra
// l'identità della categoria (nome + conteggio) su uno sfondo neutro: nessun
// asset fotografico reale è ancora disponibile, quindi nessuna forma o colore
// per-categoria inventata (DESIGN_SYSTEM.md §3: a riposo l'app è bicroma,
// Purple appare solo dove c'è interazione — qui, solo sul pannello attivo).
// Le classi is-active/is-dimmed sono globali di proposito: pilotate dallo
// script della Home, non da questo componente (che resta "no JS").
import styles from './PreviewLite.module.css';

interface Props {
  name: string;
  count: number;
  category: string;
}

const { name, count, category } = Astro.props;
---

<div class={styles.panel} data-preview-lite data-category={category}>
  <div class={styles.swatch} aria-hidden="true"></div>
  <div class={styles.caption}>
    <p class={`${styles.name} text-h3`}>{name}</p>
    <p class={`${styles.count} text-meta`}>{count} {count === 1 ? 'voce' : 'voci'}</p>
  </div>
</div>
