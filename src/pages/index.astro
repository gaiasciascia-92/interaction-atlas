---
// Home — WIREFRAMES.md §1, TASK_005.
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../ui/PageShell/PageShell.astro';
import SectionLabel from '../ui/SectionLabel/SectionLabel.astro';
import SearchBar from '../ui/SearchBar/SearchBar.astro';
import CategoryRow from '../ui/CategoryRow/CategoryRow.astro';
import PreviewLite from '../ui/PreviewLite/PreviewLite.astro';
import EntryRow from '../ui/EntryRow/EntryRow.astro';
import { publishedOrAll } from '../lib/content';
import { CATEGORY_META, CATEGORY_SLUGS } from '../lib/categories';

const effects = await getCollection('effects');
const components = await getCollection('catalog-components');

// Conteggi/"Aggiunti di recente": solo voci published; se una collection non
// ne ha ancora nessuna (oggi: tutte draft), si mostrano le voci esistenti
// invece di zero/lista vuota — interpretazione conservativa, annotata in
// docs/CHANGELOG.md, da rimuovere quando esisteranno voci pubblicate.
const visibleEffects = publishedOrAll(effects);
const visibleComponents = publishedOrAll(components);

// Decisione F (PROJECT_SPEC.md §12): l'indice V1 elenca sempre le quattro
// righe, anche a conteggio zero — niente righe Collections/Playground.
const categoryRows = CATEGORY_SLUGS.map((slug) => ({
  slug,
  name: CATEGORY_META[slug].label,
  href: CATEGORY_META[slug].href,
  count:
    slug === 'components'
      ? visibleComponents.length
      : visibleEffects.filter((e) => e.data.category === slug).length,
}));

const recent = [...visibleEffects, ...visibleComponents]
  .sort((a, b) => b.data.addedAt.localeCompare(a.data.addedAt))
  .slice(0, 5);
---

<BaseLayout title="Atlas">
  <PageShell>
    <div class="hero" data-hero>
      <h1 class="text-display" data-hero-title>Un atlante di interazioni per portfolio contemporanei.</h1>
      <a href="/e/magnetic-cursor" class="heroCaption text-meta">
        <span class="heroCaptionArrow" aria-hidden="true">↳</span> Magnetic Cursor — dal catalogo
      </a>
      <p class="text-body text-muted">
        Cataloga, confronta e scegli l'interazione giusta nel minor tempo possibile.
      </p>
    </div>
    <div class="searchWrap">
      <SearchBar />
    </div>
  </PageShell>

  <PageShell><hr class="hr" /></PageShell>

  <div class="paperBand">
    <PageShell>
      <section class="indexSection">
        <div class="indexHeader">
          <SectionLabel as="h2">Indice</SectionLabel>
        </div>
        <nav class="rowsCol" aria-label="Indice categorie" data-category-rows>
          <ul class="rows">
            {categoryRows.map((c) => <CategoryRow name={c.name} count={c.count} href={c.href} category={c.slug} />)}
          </ul>
        </nav>
        <div class="previewCol">
          <div class="previewStack">
            {categoryRows.map((c) => <PreviewLite name={c.name} count={c.count} category={c.slug} />)}
          </div>
        </div>
      </section>
    </PageShell>

    {
      recent.length > 0 && (
        <>
          <PageShell>
            <hr class="hr" />
          </PageShell>
          <PageShell>
            <section class="recentSection">
              <SectionLabel as="h2">Aggiunti di recente</SectionLabel>
              <ul class="recentRows">
                {recent.map((entry) => (
                  <EntryRow
                    title={entry.data.title}
                    category={CATEGORY_META[entry.data.category].label}
                    dna={entry.data.dna}
                    href={`/e/${entry.id}`}
                  />
                ))}
              </ul>
            </section>
          </PageShell>
        </>
      )
    }
  </div>
</BaseLayout>

<script>
  // Hero-esemplare (WIREFRAMES.md §1, MOTION_PRINCIPLES.md §1 — eccezione
  // documentata): il titolo reagisce con Magnetic Cursor solo su hover reale
  // da desktop. `(hover: hover)` esclude touch prima ancora di valutare
  // prefers-reduced-motion; anche il modulo condiviso (src/lib/magnetic-pull.ts,
  // che internamente importa GSAP) arriva per import() dinamico solo dentro
  // questo ramo, così un dispositivo mobile/touch non scarica neppure quel
  // piccolo wrapper — zero byte relativi a questa feature sul first load mobile.
  const heroEl = document.querySelector<HTMLElement>('[data-hero]');
  const heroTitleEl = document.querySelector<HTMLElement>('[data-hero-title]');
  const hoverCapable = window.matchMedia('(hover: hover)');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  if (heroEl && heroTitleEl && hoverCapable.matches && !reducedMotion.matches) {
    void import('../lib/magnetic-pull').then(({ attachMagneticPull }) => {
      void attachMagneticPull(heroEl, heroTitleEl, { radius: 140, strength: 0.15 });
    });
  }

  const rowsEl = document.querySelector('[data-category-rows]');
  const panels = document.querySelectorAll<HTMLElement>('[data-preview-lite]');

  function setActive(category: string) {
    for (const panel of panels) {
      const isMatch = panel.dataset.category === category;
      panel.classList.toggle('is-active', isMatch);
      if (!isMatch) panel.classList.remove('is-active');
      panel.classList.remove('is-dimmed');
    }
  }

  function dimActive() {
    for (const panel of panels) {
      if (panel.classList.contains('is-active')) {
        panel.classList.remove('is-active');
        panel.classList.add('is-dimmed');
      }
    }
  }

  if (rowsEl && panels.length > 0) {
    rowsEl.addEventListener('pointerover', (event) => {
      const row = (event.target as HTMLElement).closest<HTMLElement>('[data-category]');
      if (row) setActive(row.dataset.category!);
    });
    rowsEl.addEventListener('focusin', (event) => {
      const row = (event.target as HTMLElement).closest<HTMLElement>('[data-category]');
      if (row) setActive(row.dataset.category!);
    });
    rowsEl.addEventListener('pointerleave', dimActive);
    rowsEl.addEventListener('focusout', (event) => {
      const next = (event as FocusEvent).relatedTarget as Node | null;
      if (!next || !rowsEl.contains(next)) dimActive();
    });
  }
</script>

<style>
  .hero {
    grid-column: 1 / 9;
    display: grid;
    gap: var(--space-2);
    padding-block-start: var(--space-12);
  }

  .hero [data-hero-title] {
    will-change: transform;
  }

  .heroCaption {
    color: var(--color-ink-60);
    text-decoration: none;
    margin-block-start: calc(var(--space-2) * -1);
  }

  .heroCaption:hover {
    color: var(--color-primary);
  }

  /* Marker grafico (TASK_013): la freccia è un elemento grafico, non testo —
     unico punto della didascalia in Orange. */
  .heroCaptionArrow {
    color: var(--color-warm);
  }

  /* Banda di carta a piena larghezza (TASK_013): il div non eredita alcun
     vincolo di larghezza da <main>, stesso principio di AppNav/AppFooter —
     transizione netta segnata dagli <hr> che la precedono/seguono, mai un
     gradiente. */
  .paperBand {
    background: var(--color-bg-tint);
  }

  .searchWrap {
    grid-column: 1 / 8;
    padding-block-start: var(--space-4);
    padding-block-end: var(--space-12);
  }

  .hr {
    grid-column: 1 / -1;
    border: none;
    border-top: var(--border-thin);
  }

  .indexSection {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
    padding-block: var(--space-8);
  }

  .indexHeader {
    grid-column: 1 / 8;
    grid-row: 1;
    padding-block-end: var(--space-2);
  }

  .rowsCol {
    grid-column: 1 / 8;
    grid-row: 2;
  }

  .rows {
    margin: 0;
    padding: 0;
  }

  .previewCol {
    grid-column: 8 / 13;
    grid-row: 1 / 3;
  }

  .previewStack {
    position: sticky;
    top: calc(var(--space-8) + var(--space-2));
    aspect-ratio: 4 / 3;
  }

  .recentSection {
    grid-column: 1 / -1;
    display: grid;
    gap: var(--space-2);
    padding-block: var(--space-8) var(--space-16);
  }

  .recentRows {
    margin: 0;
    padding: 0;
  }

  @media (max-width: 768px) {
    .hero,
    .searchWrap {
      grid-column: 1 / -1;
    }

    .indexSection {
      grid-template-columns: 1fr;
    }

    .rowsCol,
    .previewCol {
      grid-column: 1 / -1;
    }

    .previewCol {
      display: none;
    }
  }
</style>
