---
// BaseLayout — telaio completo (TASK_003): SkipLink, AppNav, AppFooter.
import '../styles/fonts.css';
import '../styles/tokens.css';
import '../styles/base.css';
import '../styles/typography.css';
import SkipLink from '../ui/SkipLink/SkipLink.astro';
import AppNav from '../ui/AppNav/AppNav.astro';
import AppFooter from '../ui/AppFooter/AppFooter.astro';
import SearchOverlay from '../ui/SearchOverlay/SearchOverlay.astro';

interface Props {
  title: string;
  description?: string;
  navBack?: { label: string; href: string };
  navContext?: string;
}

const {
  title,
  description = 'Un atlante di interazioni per portfolio contemporanei.',
  navBack,
  navContext,
} = Astro.props;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Interaction Atlas</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} — Interaction Atlas`} />
    <meta property="og:description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="preload"
      href="/fonts/Geist-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body>
    <SkipLink />
    <AppNav back={navBack} context={navContext} />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <AppFooter />
    <SearchOverlay />
  </body>
</html>
